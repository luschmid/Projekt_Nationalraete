merge m:1 UCID_1934_2003 using "$dump\02_Processed_data\10_Directors_1934_2003\23_Panel\firm_panel_1986_remaining.dta"
order UCID_1934_2003 cname_temp year gdenr_2018 gdename
rename (UCID_1934_2003 cname_temp year gdenr_2018 gdename _merge) (UCID_1934_2003_1 cname_temp_1 year_1 gdenr_2018_1 gdename_1 _merge_1)
rename (UCID_1934_20031 cname_temp1)(UCID_1934_2003 cname_temp)
drop if _merge_1 == 2
merge m:1 UCID_1934_2003 using "$dump\02_Processed_data\10_Directors_1934_2003\23_Panel\firm_panel_1987_remaining.dta"
order UCID_1934_2003_1 cname_temp_1 year_1 gdenr_2018_1 gdename_1 UCID_1934_2003 cname_temp year gdenr_2018 gdename
rename (UCID_1934_2003 cname_temp year gdenr_2018 gdename _merge) (UCID_1934_2003_2 cname_temp_2 year_2 gdenr_2018_2 gdename_2 _merge_2)
drop CID _merge_long_geo_comp max_id2 cname_orig gdenr gdenr_2012 gdename_orig cname_group owners periode si_dummy_2 CID_str capital function signature page caddress_orig geo_merge branch_dummy gdename_extract capital_extract cname_extract ctn E_CNTR N_CNTR nb_owners fullname cname
