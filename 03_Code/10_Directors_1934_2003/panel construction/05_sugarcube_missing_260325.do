	replace `y' = usubinstr(`y', " ; ", "",.) if dup4>0
	bysort UCID_1934_2003 year (max_id2): replace `y' = `y'[_N] if dup4>0
	}

drop if dup4 > 1 

save "$dump\02_Processed_data\10_Directors_1934_2003\23_Panel\firm_panel_1934_2003_18.dta", replace
