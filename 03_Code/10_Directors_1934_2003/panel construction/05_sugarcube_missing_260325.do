append using "$dump\02_Processed_data\10_Directors_1934_2003\23_Panel\firm_panel_obs_gaps"
drop tag obs_total dup_panel maxpanel minpanel group_gap2 gap2 dup dup2
	
	bysort CID year:  gen dup = cond(_N==1,0,_n)
	drop if dup > 1
	
